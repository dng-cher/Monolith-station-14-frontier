<Button xmlns="https://spacestation14.io"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        ClipText="False"
        MinSize="132 34"
        MaxSize="210 34"
        HorizontalExpand="False"
        Margin="0"
        Text="">

    <BoxContainer Name="LayoutRoot"
                  Orientation="Horizontal"
                  SeparationOverride="6"
                  HorizontalExpand="True"
                  VerticalExpand="True"
                  HorizontalAlignment="Right"
                  Margin="8 4 8 4">

        <TextureRect Name="CurrencyIcon"
                     Stretch="KeepAspectCentered"
                     MinSize="16 16"
                     MaxSize="16 16"
                     VerticalAlignment="Center"
                     Visible="False" />

        <Label Name="PriceLabel"
               HorizontalAlignment="Right"
               HorizontalExpand="True"
               VerticalAlignment="Center"
               ClipText="False"
               MinWidth="24"
               Text="0" />

        <Label Name="UnitPriceLabel"
               Visible="False"
               Text="" />
    </BoxContainer>
</Button>
