<PanelContainer xmlns="https://spacestation14.io"
                xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                xmlns:controls="clr-namespace:Content.Client._Forge.Trade.Controls"
                HorizontalExpand="True"
                VerticalExpand="True">

    <BoxContainer Name="BodyRow"
                  Orientation="Horizontal"
                  HorizontalExpand="True"
                  VerticalExpand="True"
                  SeparationOverride="6"
                  Margin="6">

        <!-- Sidebar -->
        <PanelContainer Name="CategoriesPanel"
                        VerticalExpand="True"
                        MinWidth="238">
            <BoxContainer Orientation="Vertical"
                          VerticalExpand="True"
                          SeparationOverride="0">

                <Label Name="TabHeading"
                       StyleClasses="LabelKeyText"
                       Margin="8 6 8 5" />

                <controls:NcCategoryBar Name="CategoryBar"
                                        VerticalExpand="True"
                                        HorizontalExpand="True"
                                        Margin="0 0 0 3" />
            </BoxContainer>
        </PanelContainer>

        <!-- Divider -->
        <PanelContainer Name="CategoriesDivider"
                        MinWidth="1"
                        Margin="0 1 0 1" />

        <!-- Content -->
        <BoxContainer Name="ContentColumn"
                      Orientation="Vertical"
                      VerticalExpand="True"
                      HorizontalExpand="True"
                      SeparationOverride="5">

            <PanelContainer Name="CategoryHeaderPanel"
                            HorizontalExpand="True"
                            MinHeight="38">
                <Label Name="CategoryHeader"
                       Margin="10 5 10 5"
                       Text="{Loc 'nc-store-select-category'}" />
            </PanelContainer>

            <BoxContainer Name="MassSellRow"
                          Orientation="Horizontal"
                          Visible="False"
                          Margin="0 0 0 2">
                <Button Name="MassSellButton"
                        MinWidth="260" />
            </BoxContainer>

            <controls:NcListingsPane Name="Pane"
                                     VerticalExpand="True"
                                     HorizontalExpand="True" />
        </BoxContainer>

    </BoxContainer>
</PanelContainer>
