<!-- Forge-Change-Start: three-column gunnery UI with collapsible side panels and edge-mounted toggles. -->
<controls:FancyWindow xmlns="https://spacestation14.io"
            xmlns:gfx="clr-namespace:Robust.Client.Graphics;assembly=Robust.Client"
            xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls"
            xmlns:ui="clr-namespace:Content.Client._Mono.FireControl.UI"
            xmlns:shields="clr-namespace:Content.Client._Crescent.ShipShields.UI"
            Title="{Loc 'gunnery-window-title'}"
            SetSize="1300 800"
            MinHeight="700">
    <BoxContainer Name="RootBox" Orientation="Horizontal">
        <!-- Left: collapsible controls -->
        <PanelContainer Name="ControlsPanel" MinWidth="300" MaxWidth="300" HorizontalExpand="False"
                        VerticalExpand="True" Margin="5 5 0 5">
            <PanelContainer.PanelOverride>
                <gfx:StyleBoxFlat BorderThickness="3" BorderColor="#35434d" BackgroundColor="#1f1f1f"/>
            </PanelContainer.PanelOverride>
            <BoxContainer Name="ControlsBox" Orientation="Vertical" Margin="4">
                <controls:StripeBack MinSize="36 36">
                    <Label Name="ServerStatus" Text="{Loc 'gunnery-window-disconnected'}"
                           StyleClasses="LabelKeyText" HorizontalAlignment="Center"/>
                </controls:StripeBack>
                <Button Name="RefreshButton" Access="Public" Text="{Loc admin-logs-refresh}"
                        StyleClasses="ButtonSquare" Margin="0 2"/>
                <CheckBox Name="ShowIFFCheckbox" Access="Public" Text="{Loc 'gunnery-show-iff'}"
                          Margin="0 2" Pressed="True"/>
                <BoxContainer Orientation="Vertical" Margin="0 2">
                    <Label Text="{Loc 'gunnery-iff-search'}"/>
                    <LineEdit Name="IffSearchCriteria" Access="Public" HorizontalExpand="True"/>
                </BoxContainer>
                <PanelContainer Name="ShieldPanel" Visible="False" Margin="0 2">
                    <BoxContainer Orientation="Vertical" HorizontalExpand="True">
                        <Label Text="{Loc 'gunnery-shield-label'}"/>
                        <shields:ShipShieldBar Name="ShieldBar" HorizontalExpand="True" MinHeight="20"/>
                    </BoxContainer>
                </PanelContainer>
                <!-- Forge-Change: weapon preset lists -->
                <controls:StripeBack MinSize="32 32" Margin="0 4 0 0">
                    <Label Text="{Loc 'gunnery-presets-title'}" HorizontalAlignment="Center" StyleClasses="StatusFieldTitle"/>
                </controls:StripeBack>
                <BoxContainer Orientation="Horizontal" Margin="0 2">
                    <LineEdit Name="Preset1NameEdit" Access="Public" HorizontalExpand="True" PlaceHolder="{Loc gunnery-preset-name-placeholder}"/>
                    <Button Name="Preset1LoadButton" Access="Public" Text="{Loc gunnery-preset-load}" MinWidth="72" Margin="4 0 0 0"/>
                </BoxContainer>
                <BoxContainer Orientation="Horizontal" Margin="0 2">
                    <LineEdit Name="Preset2NameEdit" Access="Public" HorizontalExpand="True" PlaceHolder="{Loc gunnery-preset-name-placeholder}"/>
                    <Button Name="Preset2LoadButton" Access="Public" Text="{Loc gunnery-preset-load}" MinWidth="72" Margin="4 0 0 0"/>
                </BoxContainer>
                <BoxContainer Orientation="Horizontal" Margin="0 2">
                    <LineEdit Name="Preset3NameEdit" Access="Public" HorizontalExpand="True" PlaceHolder="{Loc gunnery-preset-name-placeholder}"/>
                    <Button Name="Preset3LoadButton" Access="Public" Text="{Loc gunnery-preset-load}" MinWidth="72" Margin="4 0 0 0"/>
                </BoxContainer>
                <BoxContainer Orientation="Vertical" Margin="0 2">
                    <OptionButton Name="PresetSaveTarget" Access="Public" HorizontalExpand="True"/>
                    <Button Name="SavePresetButton" Access="Public" Text="{Loc gunnery-preset-save}"
                            StyleClasses="ButtonSquare" HorizontalExpand="True" Margin="0 2 0 0"/>
                </BoxContainer>
                <Label Name="PresetStatusLabel" Access="Public" HorizontalAlignment="Center" Margin="0 2 0 0"/>
            </BoxContainer>
        </PanelContainer>

        <!-- Center: radar with always-visible collapse handles -->
        <LayoutContainer Name="RadarHost" HorizontalExpand="True" VerticalExpand="True" Margin="0 5">
            <ui:FireControlNavControl Name="NavRadar"/>
            <Button Name="ControlsPanelToggle" Access="Public" Text="«"
                    StyleClasses="ButtonSquare" MinSize="22 80"/>
            <Button Name="WeaponsPanelToggle" Access="Public" Text="»"
                    StyleClasses="ButtonSquare" MinSize="22 80"/>
        </LayoutContainer>

        <!-- Right: collapsible weapons -->
        <PanelContainer Name="WeaponsPanel" MinWidth="300" MaxWidth="300" HorizontalExpand="False"
                        VerticalExpand="True" Margin="0 5 5 5">
            <PanelContainer.PanelOverride>
                <gfx:StyleBoxFlat BorderThickness="3" BorderColor="#35434d" BackgroundColor="#1f1f1f"/>
            </PanelContainer.PanelOverride>
            <BoxContainer Orientation="Vertical" Margin="4">
                <controls:StripeBack MinSize="36 36">
                    <Label Name="WeaponsLabel" Text="{Loc 'gunnery-guns'}" HorizontalAlignment="Center" StyleClasses="StatusFieldTitle"/>
                </controls:StripeBack>
                <BoxContainer Orientation="Horizontal" Margin="0 2">
                    <Button Name="SelectAllButton" Access="Public" Text="{Loc 'gunnery-select-all'}"
                            StyleClasses="OpenRight" HorizontalExpand="True"/>
                    <Button Name="UnselectAllButton" Access="Public" Text="{Loc 'gunnery-unselect-all'}"
                            StyleClasses="OpenLeft" HorizontalExpand="True"/>
                </BoxContainer>
                <BoxContainer Orientation="Vertical" Margin="0 2">
                    <Button Name="SelectBallisticButton" Access="Public" Text="{Loc gunnery-select-ballistic}"
                            StyleClasses="ButtonSquare" HorizontalExpand="True" Margin="0 0 0 2"/>
                    <Button Name="SelectEnergyButton" Access="Public" Text="{Loc gunnery-select-energy}"
                            StyleClasses="ButtonSquare" HorizontalExpand="True" Margin="0 0 0 2"/>
                    <Button Name="SelectMissileButton" Access="Public" Text="{Loc gunnery-select-missiles}"
                            StyleClasses="ButtonSquare" HorizontalExpand="True"/>
                </BoxContainer>
                <PanelContainer VerticalExpand="True" Margin="0 2 0 0">
                    <PanelContainer.PanelOverride>
                        <gfx:StyleBoxFlat BackgroundColor="#111111"/>
                    </PanelContainer.PanelOverride>
                    <ScrollContainer VerticalExpand="True" HorizontalExpand="True" HScrollEnabled="False">
                        <BoxContainer Name="ControllablesBox" Orientation="Vertical" HorizontalExpand="True"/>
                    </ScrollContainer>
                </PanelContainer>
            </BoxContainer>
        </PanelContainer>
    </BoxContainer>
</controls:FancyWindow>
<!-- Forge-Change-End -->
